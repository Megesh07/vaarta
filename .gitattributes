# Normalize line endings for everyone, regardless of a contributor's local core.autocrlf setting.
# Without this, Windows/macOS/Linux collaborators produce noisy whole-file diffs on every edit.
* text=auto eol=lf

*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.gradle text eol=lf

# Binary — never touch
*.png binary
*.jpg binary
*.jks binary
*.keystore binary
*.apk binary
*.aab binary
*.jar binary
