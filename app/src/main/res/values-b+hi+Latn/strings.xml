    <!-- Help v2 remainder — SAFETY-CRITICAL, needs native review. -->
    <string name="help_warn_family_message">VAARTA: careful raho — police/CBI/courier bankar scammers logon ko call kar rahe hain, arrest ki threat de rahe hain, aur paise ya OTP maang rahe hain. Koi bhi real officer phone ya video call pe kisi ko arrest nahi karta. Kabhi OTP mat do ya paise mat bhejo. Pressure mein aao toh call kaat do aur 1930 pe call karo.</string>
    <string name="help_scammed_step_1">Abhi ruko — aur paise mat bhejo. Scammers often \"ek last payment\" maangte hain paise wapas karne ke liye. Yeh bhi scam ka hissa hai.</string>
    <string name="help_scammed_step_2">Turant 1930 pe call karke report karo. Jitni jaldi call karoge, paise rukne ka chance utna better hoga.</string>
    <string name="help_scammed_step_3">Turant apne bank ko batao. Transaction freeze karne aur aage ki debits rokne ke liye kaho.</string>
    <string name="help_scammed_step_4">Numbers, transaction IDs, aur screenshots ke saath cybercrime.gov.in pe complaint file karo.</string>
    <string name="help_scammed_step_5">Agar aapne OTP, PIN, ya password share kiya hai, toh use change karo aur bank ki extra security on karo.</string>
    <string name="help_scammed_step_6">Sab kuch safe rakho — call logs, messages, aur payment receipts — evidence ke taur pe.</string>
    <string name="help_scammed_step_7">Apne family ko batao taaki woh help kar sakein aur alert rahein.</string>
    <string name="help_title">Help paao aur report karo</string>
    <string name="help_call_1930">1930 pe call karo</string>
    <string name="help_share_as_text">Text ke roop mein share karo</string>
