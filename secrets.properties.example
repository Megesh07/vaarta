# Copy this file to `secrets.properties` (same directory) and fill in your own key.
# `secrets.properties` is git-ignored — it will NEVER be committed. This example file is the
# only one tracked in git, so a fresh clone knows what to create.
#
# Get a free Gemini API key: https://aistudio.google.com/apikey
# Needed for: the opt-in live-AI suggestion layer (ADR-0002). The app builds and runs fully
# without it — Manual Mode, the deterministic risk engine, and complaint export all work with
# no key at all. Missing/blank key just disables the AI opt-in toggle in-app.

GEMINI_API_KEY=your_key_here

# Get a free Safe Browsing v4 API key (non-commercial tier): https://developers.google.com/safe-browsing/v4/get-started
# Needed for: the scam-link checker's second lookup (URLhaus needs no key and always runs). The
# app builds and runs fully without it — LinkChecker just skips the Safe Browsing call and relies
# on URLhaus alone (fails closed, never reassures).

SAFE_BROWSING_API_KEY=your_key_here
