  "questions": [
    {
      "id": "Q_STATION",
      "stage": "AUTHORITY",
      "category": "AUTHORITY_CLAIM",
      "text": {
        "en": "Which police station are you calling from? I will call them directly.",
        "hi": "आप किस थाने से बोल रहे हैं? मैं खुद वहाँ कॉल करूँगा।"
      },
      "goal": "A real officer can name a verifiable station; the script cannot."
    },
    {
      "id": "Q_VERIFY_1930",
      "stage": "AUTHORITY",
      "category": "LEGAL_THREAT",
      "text": {
        "en": "I will verify this with the 1930 cyber helpline and call back.",
        "hi": "मैं इसे 1930 साइबर हेल्पलाइन से सत्यापित करके वापस कॉल करूँगा।"
      },
      "goal": "Hanging up to verify breaks the isolation cage; scripts forbid it."
    },
    {
      "id": "Q_ADD_FAMILY",
      "stage": "ISOLATION",
      "category": "ISOLATION_ORDER",
      "text": {
        "en": "I am adding my son/daughter to this call now.",
        "hi": "मैं अभी अपने बेटे/बेटी को इस कॉल में जोड़ रहा हूँ।"
      },
      "goal": "Direct isolation breaker; refusal is itself a near-certain scam tell."
